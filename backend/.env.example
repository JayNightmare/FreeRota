PORT=4000
MONGODB_URI=mongodb://localhost:27017/freerota
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
FRONTEND_ORIGIN=http://localhost:8081

# SMTP configuration for verification and password-reset emails.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=FreeRota <no-reply@freerota.local>

# Optional: when provided, backend uses Mailtrap API transport instead of SMTP.
MAILTRAP_TOKEN=

# Auth link targets for mobile deep links and optional web fallback.
APP_DEEP_LINK_BASE=freerota://auth
APP_WEB_BASE_URL=

# Optional: support and admin-approval Discord webhook endpoints.
DISCORD_SUPPORT_WEBHOOK_URL=
DISCORD_ADMIN_APPROVAL_WEBHOOK_URL=
DISCORD_ENTERPRISE_WEBHOOK_URL=

# Optional: usernames allowed to approve the first admin application when no admins exist yet.
ADMIN_BOOTSTRAP_USERNAMES=
