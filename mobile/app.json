{
	"expo": {
		"name": "FreeRota",
		"slug": "freerota",
		"scheme": "freerota",
		"version": "0.1.0",
		"orientation": "portrait",
		"userInterfaceStyle": "automatic",
		"icon": "./images/FreeRota.png",
		"splash": {
			"resizeMode": "contain",
			"backgroundColor": "#FFFFFF"
		},
		"updates": {
			"fallbackToCacheTimeout": 0
		},
		"assetBundlePatterns": ["**/*"],
		"ios": {
			"supportsTablet": true
		},
		"android": {
			"adaptiveIcon": {
				"foregroundImage": "./images/FreeRota.png",
				"backgroundColor": "#FFFFFF"
			}
		},
		"extra": {
			"api": {
				"port": 4000,
				"graphqlPath": "/graphql"
			}
		},
		"plugins": [
			"@react-native-community/datetimepicker",
			[
				"expo-calendar",
				{
					"calendarPermission": "Allow FreeRota to access your calendar events for rota sync."
				}
			]
		]
	}
}
